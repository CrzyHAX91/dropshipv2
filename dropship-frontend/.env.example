# API Configuration
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# Environment
VITE_NODE_ENV=development

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SOCIAL_LOGIN=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_CHAT=true

# External Services
VITE_GOOGLE_ANALYTICS_ID=your_ga_id
VITE_SENTRY_DSN=your_sentry_dsn
VITE_MIXPANEL_TOKEN=your_mixpanel_token

# Social Media
VITE_FACEBOOK_APP_ID=your_facebook_app_id
VITE_TWITTER_API_KEY=your_twitter_api_key

# Maps and Geolocation
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key

# Payment Gateways
VITE_STRIPE_PUBLIC_KEY=your_stripe_public_key
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id

# UI Configuration
VITE_APP_NAME=Dropship Platform
VITE_SUPPORT_EMAIL=support@yourdomain.com
VITE_CONTACT_PHONE=+1-234-567-8900

# Performance
VITE_ENABLE_PWA=true
VITE_ENABLE_SERVICE_WORKER=true
VITE_ENABLE_CACHE=true

# Development Tools
VITE_ENABLE_DEVTOOLS=true
VITE_ENABLE_MOCK_API=false
VITE_ENABLE_DEBUG_LOGGING=true

# Localization
VITE_DEFAULT_LANGUAGE=en
VITE_SUPPORTED_LANGUAGES=en,es,fr

# Theme
VITE_PRIMARY_COLOR=#1976d2
VITE_SECONDARY_COLOR=#dc004e
VITE_FONT_FAMILY=Roboto, sans-serif

# Security
VITE_ENABLE_CSP=true
VITE_ENABLE_HSTS=true
VITE_ENABLE_XSS_PROTECTION=true
